<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lgy.ess_monitoring.dao.BoardDAO">

    <sql id="boardColumns">
        b.board_no,
        b.member_id,
        b.board_type,
        m.member_name,
        b.board_title,
        b.board_content,
        b.board_hit,
        b.created_at,
        b.updated_at
    </sql>

    <sql id="boardFrom">
        FROM board b
        JOIN ess_member m
          ON b.member_id = m.member_id
    </sql>

    <sql id="boardTypeCriteria">
        <if test="boardType != null and boardType != ''">
            AND b.board_type = #{boardType}
        </if>
    </sql>

    <sql id="searchCriteria">
        <if test="keyword != null and keyword != '' and type != null and type != ''">
            <choose>
                <when test='type == "T"'>
                    AND b.board_title LIKE CONCAT('%', #{keyword}, '%')
                </when>

                <when test='type == "C"'>
                    AND b.board_content LIKE CONCAT('%', #{keyword}, '%')
                </when>

                <when test='type == "W"'>
                    AND m.member_name LIKE CONCAT('%', #{keyword}, '%')
                </when>

                <when test='type == "TC"'>
                    AND (
                        b.board_title LIKE CONCAT('%', #{keyword}, '%')
                        OR b.board_content LIKE CONCAT('%', #{keyword}, '%')
                    )
                </when>

                <when test='type == "TW"'>
                    AND (
                        b.board_title LIKE CONCAT('%', #{keyword}, '%')
                        OR m.member_name LIKE CONCAT('%', #{keyword}, '%')
                    )
                </when>

                <when test='type == "TCW"'>
                    AND (
                        b.board_title LIKE CONCAT('%', #{keyword}, '%')
                        OR b.board_content LIKE CONCAT('%', #{keyword}, '%')
                        OR m.member_name LIKE CONCAT('%', #{keyword}, '%')
                    )
                </when>
            </choose>
        </if>
    </sql>

    <select id="list"
            resultType="com.lgy.ess_monitoring.dto.BoardDTO">

        SELECT
            <include refid="boardColumns"/>

        <include refid="boardFrom"/>

        ORDER BY b.board_no DESC

    </select>

    <select id="listWithPaging"
            parameterType="com.lgy.ess_monitoring.dto.Criteria"
            resultType="com.lgy.ess_monitoring.dto.BoardDTO">

        SELECT
            <include refid="boardColumns"/>

        <include refid="boardFrom"/>

        <where>
            <include refid="boardTypeCriteria"/>
            <include refid="searchCriteria"/>
        </where>

        ORDER BY
		    CASE
		        WHEN b.board_type = 'NOTICE' THEN 0
		        ELSE 1
		    END,
		    b.board_no DESC

        LIMIT #{amount}
        OFFSET #{pageStart}

    </select>

    <select id="getTotalCount"
            parameterType="com.lgy.ess_monitoring.dto.Criteria"
            resultType="int">

        SELECT COUNT(*)

        <include refid="boardFrom"/>

        <where>
            <include refid="boardTypeCriteria"/>
            <include refid="searchCriteria"/>
        </where>

    </select>

    <insert id="write" parameterType="hashmap">

        INSERT INTO board (
            member_id,
            board_type,
            board_title,
            board_content
        ) VALUES (
            #{memberId},
            #{boardType},
            #{boardTitle},
            #{boardContent}
        )

    </insert>

    <select id="contentView"
            parameterType="hashmap"
            resultType="com.lgy.ess_monitoring.dto.BoardDTO">

        SELECT
            <include refid="boardColumns"/>

        <include refid="boardFrom"/>

        WHERE b.board_no = #{boardNo}

    </select>

    <update id="modify" parameterType="hashmap">

        UPDATE board
           SET board_title = #{boardTitle},
               board_content = #{boardContent},
               updated_at = NOW()
         WHERE board_no = #{boardNo}

    </update>

    <delete id="delete" parameterType="hashmap">

        DELETE FROM board
         WHERE board_no = #{boardNo}

    </delete>

    <update id="increaseHit" parameterType="int">

        UPDATE board
           SET board_hit = board_hit + 1
         WHERE board_no = #{value}

    </update>

    <select id="getWriterMemberId"
            parameterType="int"
            resultType="int">

        SELECT member_id
          FROM board
         WHERE board_no = #{value}

    </select>

    <select id="getRecentNoticeList"
            resultType="com.lgy.ess_monitoring.dto.BoardDTO">

        SELECT
            <include refid="boardColumns"/>

        <include refid="boardFrom"/>

        WHERE b.board_type = 'NOTICE'

        ORDER BY b.board_no DESC

        LIMIT 5

    </select>

</mapper>