<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>전문 통합 관제 시스템 - ESS-M.S</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        /* [1] 테마 변수 */
        :root {
            --bg-main: #0b1426; --bg-card: #16213e; --bg-sidebar: #1a2647;
            --text-main: #ffffff; --text-sub: #a0aec0; --border: #2d3748;
            --accent: #00d2ff; --table-hover: #1e2d4d; --gray-off: #2d3748;
            --header-bg: #1a2647;
            --footer-bg: #070d19; /* 푸터 배경 추가 */
        }
        [data-theme='light'] {
            --bg-main: #f0f2f5; --bg-card: #ffffff; --bg-sidebar: #ffffff;
            --text-main: #1a202c; --text-sub: #718096; --border: #e2e8f0;
            --accent: #3182ce; --table-hover: #edf2f7; --gray-off: #cbd5e0;
            --header-bg: #ffffff;
            --footer-bg: #e2e8f0; /* 푸터 라이트 모드 배경 */
        }

        body { margin: 0; padding: 0; background: var(--bg-main); color: var(--text-main); font-family: 'Pretendard', sans-serif; transition: 0.3s; overflow: hidden; }

        /* [2] 추가된 헤더 스타일 (테마 연동) */
        header { 
            background: var(--header-bg); 
            border-bottom: 1px solid var(--border); 
            height: 60px; 
            display: flex; 
            align-items: center;
            position: relative;
            z-index: 100;
        }
        header .container { 
            width: 100%; 
            padding: 0 30px; 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
        }
        .logo { 
            font-size: 1.4rem; 
            color: var(--accent); 
            margin: 0; 
            font-weight: 800; 
            letter-spacing: -1px; 
        }
        header nav ul { list-style: none; display: flex; gap: 25px; margin: 0; padding: 0; align-items: center; }
        header nav ul li a { 
            text-decoration: none; 
            color: var(--text-sub); 
            font-size: 0.9rem; 
            font-weight: 500; 
            transition: 0.2s; 
        }
        header nav ul li a:hover { color: var(--accent); }
        .login-btn { 
            background: var(--accent); 
            color: white !important; 
            padding: 6px 16px; 
            border-radius: 6px; 
            font-weight: 600; 
            cursor: pointer;
        }

        /* [3] 대시보드 레이아웃 조정 (헤더 높이만큼 차감) */
        .dashboard { display: grid; grid-template-columns: 240px 1fr 320px; height: calc(100vh - 60px); }

        /* 사이드바 */
        .sidebar { background: var(--bg-sidebar); border-right: 1px solid var(--border); padding: 20px; }
        .logo-box { background: var(--accent); color: white; padding: 15px; border-radius: 10px; font-weight: bold; text-align: center; margin-bottom: 20px; cursor: pointer; }
        .loc-item { padding: 12px; cursor: pointer; border-bottom: 1px solid var(--border); color: var(--text-sub); }
        .loc-item.active { color: var(--accent); font-weight: bold; }

        /* 메인 컨텐츠 및 네비게이션 - 푸터 연동을 위해 flex 변경 */
        .main-content { display: flex; flex-direction: column; overflow-y: auto; background: var(--bg-main); }
        .content-inner { padding: 20px; flex: 1; display: flex; flex-direction: column; gap: 20px; }
        .top-nav { display: flex; gap: 30px; border-bottom: 1px solid var(--border); padding-bottom: 10px; }
        .top-nav span { cursor: pointer; color: var(--text-sub); font-size: 0.9rem; padding: 5px 10px; }
        .top-nav span.active { color: var(--accent); border-bottom: 2px solid var(--accent); font-weight: bold; }

        /* 화면 전환용 섹션 */
        .content-section { display: none; flex-direction: column; gap: 20px; }
        .content-section.active { display: flex; }

        /* 게이지 보드 */
        .gauge-board { display: grid; grid-template-columns: 1.4fr 1fr 1fr 1fr 1fr; gap: 10px; background: var(--bg-card); border-radius: 15px; padding: 20px; border: 1px solid var(--border); align-items: flex-start; }
        .gauge-item { text-align: center; position: relative; border-right: 1px solid var(--border); height: 220px; display: flex; flex-direction: column; align-items: center; }
        .gauge-item:last-child { border-right: none; }
        .gauge-item h4 { margin: 0 0 15px 0; font-size: 0.8rem; color: var(--text-sub); position: static; transform: none; }

        /* 시스템 상태 전용 레이아웃 */
        .status-wrapper { display: flex; flex-direction: column; align-items: center; gap: 12px; }
        .status-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px 20px; text-align: left; }
        .legend-item { display: flex; align-items: center; gap: 8px; font-size: 0.75rem; color: var(--text-sub); }
        .color-box { width: 12px; height: 12px; border-radius: 2px; background: var(--gray-off); transition: 0.3s; }
        .box-normal.active { background: #48bb78; box-shadow: 0 0 8px #48bb78; }
        .box-common.active { background: #3498db; box-shadow: 0 0 8px #3498db; }
        .box-warn.active   { background: #f6ad55; box-shadow: 0 0 8px #f6ad55; }
        .box-fault.active  { background: #f56565; box-shadow: 0 0 8px #f56565; }

        .gauge-val { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 1.2rem; font-weight: bold; }

        /* 테이블 */
        .device-table-card { background: var(--bg-card); border-radius: 15px; padding: 20px; border: 1px solid var(--border); }
        table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }
        th { text-align: left; color: var(--text-sub); padding: 12px; border-bottom: 1px solid var(--border); }
        td { padding: 10px; border-bottom: 1px solid var(--border); }
        .tag { padding: 2px 6px; border-radius: 4px; font-size: 0.7rem; }
        .tag-run { background: rgba(72, 187, 120, 0.2); color: #48bb78; }

        /* 분석 뷰 전용 */
        .analysis-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; }
        .chart-full-card { background: var(--bg-card); border-radius: 15px; padding: 20px; border: 1px solid var(--border); height: 400px; }

        /* 푸터 스타일 */
        footer { background: var(--footer-bg); border-top: 1px solid var(--border); padding: 40px 20px; color: var(--text-sub); font-size: 0.85rem; }
        .footer-content { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 40px; }
        .footer-logo { color: var(--accent); font-size: 1.5rem; margin: 0 0 10px 0; }
        .footer-links h4, .footer-sns h4 { color: var(--text-main); margin-bottom: 15px; }
        .footer-links ul { list-style: none; padding: 0; }
        .footer-links li { margin-bottom: 8px; }
        .footer-links a { color: var(--text-sub); text-decoration: none; transition: 0.2s; }
        .footer-links a:hover { color: var(--accent); }
        .sns-icons span { margin-right: 15px; cursor: pointer; }
        .copyright { margin-top: 20px; font-size: 0.75rem; opacity: 0.6; }

        /* 우측 패널 및 로그/알림 */
        .right-panel { background: var(--bg-sidebar); border-left: 1px solid var(--border); padding: 20px; display: flex; flex-direction: column; gap: 15px; overflow-y: auto; }
        .time-box { background: white; color: black; border-radius: 20px; padding: 8px; text-align: center; font-weight: bold; font-size: 0.9rem; }
        
        .panel-box { background: rgba(0,0,0,0.2); padding: 15px; border-radius: 10px; display: flex; flex-direction: column; gap: 10px; }
        .log-item, .notice-item { font-size: 0.75rem; border-bottom: 1px solid rgba(255,255,255,0.05); padding: 5px 0; }
        .log-header, .notice-header { display: flex; justify-content: space-between; margin-bottom: 3px; }
        .log-status { font-size: 0.65rem; padding: 1px 4px; border-radius: 3px; }
        .status-success { background: rgba(72,187,120,0.2); color: #48bb78; }
        .status-fail { background: rgba(245,101,101,0.2); color: #f56565; }
        
        .notice-badge { padding: 2px 5px; border-radius: 3px; font-weight: bold; font-size: 0.65rem; margin-right: 5px; }
        .badge-critical { background: #f56565; color: white; }
        .badge-info { background: #4299e1; color: white; }

        .theme-btn { position: fixed; bottom: 20px; right: 20px; padding: 10px 20px; border-radius: 30px; border: none; background: var(--accent); color: white; font-weight: bold; cursor: pointer; z-index: 999; }
    </style>
</head>
<body>

<header>
    <div class="container">
        <h1 class="logo" onclick="location.href='1.main.html'" style="cursor:pointer;">ESS-M.S</h1>
        <nav>
            <ul>
                <li><a href="1.main.html">홈</a></li>
                <li><a href="3.serviceInfo.html">서비스 소개</a></li>
                <li><a href="2.contact.html">문의게시판</a></li>
                <li id="auth-menu">
                    <a href="javascript:void(0)" class="login-btn" onclick="openLoginWindow()">로그인</a>
                </li>
            </ul>
        </nav>
    </div>
</header>

<button class="theme-btn" onclick="toggleTheme()">🌓 테마 전환</button>

<div class="dashboard">
    <aside class="sidebar">
        <div class="logo-box" onclick="location.href='1.main.html'">관제 대시보드</div>
        <div class="loc-item active">대전소프트 본사</div>
        <div class="loc-item">대전 제1 발전소</div>
        <div class="loc-item">대전 제2 발전소</div>
    </aside>

    <main class="main-content">
        <div class="content-inner">
            <nav class="top-nav">
    <span id="nav-main" class="active" onclick="switchView('main')">실시간 관제</span>
    <span id="nav-analysis" onclick="switchView('analysis')">분석 리포트</span>
</nav>

<div id="view-analysis" class="content-section">
    <div class="chart-full-card">
        <canvas id="analysisChart"></canvas>
    </div>

    <div class="card" style="margin-top: 20px;">
        <div class="card-header">
            <h3 class="card-title">📂 월별 운영 데이터 다운로드</h3>
        </div>
        <div style="padding: 20px;">
            <table class="report-table">
                <thead>
                    <tr>
                        <th>집계 월</th>
                        <th>리포트 명칭</th>
                        <th>총 발전량</th>
                        <th>상태</th>
                        <th>다운로드</th>
                    </tr>
                </thead>
                <tbody id="reportList">
                    </tbody>
            </table>
        </div>
    </div>
</div>

            <section id="view-main" class="content-section active">
                <div class="gauge-board">
                    <div class="gauge-item">
                        <h4>시스템 상태</h4>
                        <div class="status-wrapper">
                            <div style="width: 100px; height: 100px; position: relative;">
                                <canvas id="statusGauge"></canvas>
                                <div class="gauge-val" id="status-text">정상</div>
                            </div>
                            <div class="status-grid">
                                <div class="legend-item"><div id="box-warn" class="color-box box-warn"></div>위험</div>
                                <div class="legend-item"><div id="box-normal" class="color-box box-normal"></div>정상</div>
                                <div class="legend-item"><div id="box-fault" class="color-box box-fault"></div>고장</div>
                                <div class="legend-item"><div id="box-common" class="color-box box-common"></div>보통</div>
                            </div>
                        </div>
                    </div>
                    <div class="gauge-item">
                        <h4>발전효율</h4>
                        <div style="width: 100px; height: 100px; position: relative;">
                            <canvas id="c2"></canvas>
                            <div class="gauge-val">99%</div>
                        </div>
                    </div>
                    <div class="gauge-item">
                        <h4>운영지수</h4>
                        <div style="width: 100px; height: 100px; position: relative;">
                            <canvas id="c3"></canvas>
                            <div class="gauge-val" style="font-size: 1.8rem;">90</div>
                        </div>
                    </div>
                    <div class="gauge-item">
                        <h4>설비효율</h4>
                        <div style="width: 100px; height: 100px; position: relative;">
                            <canvas id="c4"></canvas>
                            <div class="gauge-val">80%</div>
                        </div>
                    </div>
                    <div class="gauge-item">
                        <h4>가동률</h4>
                        <div style="width: 100px; height: 100px; position: relative;">
                            <canvas id="c5"></canvas>
                            <div class="gauge-val">95%</div>
                        </div>
                    </div>
                </div>

                <div class="device-table-card">
                    <table>
                        <thead>
                            <tr><th>DEVICE</th><th>상태</th><th>발전(kW)</th><th>전압(V)</th><th>온도(℃)</th><th>효율</th></tr>
                        </thead>
                        <tbody id="device-list"></tbody>
                    </table>
                </div>
            </section>

            <section id="view-analysis" class="content-section">
                <div class="analysis-grid">
                    <div class="chart-full-card">
                        <h4 style="color: var(--accent); margin-top:0;">📅 기간별 발전량 및 절감 요금 추이</h4>
                        <div style="height: 320px;"><canvas id="analysisChart"></canvas></div>
                    </div>
                    <div class="device-table-card">
                        <h4 style="margin-top:0;">분석 통계 요약</h4>
                        <div style="line-height: 2.2; font-size: 0.9rem;">
                            <p>평균 효율: <span style="color:var(--accent)">98.2%</span></p>
                            <p>누적 발전: <span style="color:var(--accent)">4,250 kW</span></p>
                            <p>누적 절감 요금: <span style="color:#48bb78; font-weight:bold;">₩ 637,500</span></p>
                            <hr style="border:0; border-top:1px solid var(--border)">
                            <p style="color:var(--text-sub); font-size: 0.8rem;">※ 요금 산정 기준: 150원/kWh</p>
                            <p style="color:var(--text-sub); font-size: 0.8rem;">※ 최근 30일 데이터 기준</p>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <footer>
            <div class="footer-content">
                <div class="footer-info">
                    <h2 class="footer-logo">ESS-M.S</h2>
                    <p>스마트 에너지 모니터링 시스템 전문 기업</p>
                    <address>
                        부산광역시 범내골 kh 학원 <br>
                        대표전화: 051-123-4567 | 이메일: info@ess-ms.com
                    </address>
                    <p class="copyright">&copy; 2026 ESS-Monitoring System. All Rights Reserved.</p>
                </div>
                <div class="footer-links">
                    <h4>Quick Links</h4>
                    <ul>
                        <li><a href="1.main.html">홈</a></li>
                        <li><a href="3.serviceInfo.html">서비스 소개</a></li>
                        <li><a href="2.contact.html">문의게시판</a></li>
                        <li><a href="7.newsupdate.html">최신 정보</a></li>
                    </ul>
                </div>
                <div class="footer-sns">
                    <h4>Follow Us</h4>
                    <div class="sns-icons">
                        <span>Blog</span> <span>LinkedIn</span> <span>Youtube</span>
                    </div>
                </div>
            </div>
        </footer>
    </main>

    <aside class="right-panel">
        <div class="time-box" id="clock">로딩 중...</div>
        
        <div class="panel-box">
            <h5 style="margin:0; color:#f6ad55;">🔔 실시간 알림</h5>
            <div id="notice-container">
                <div class="notice-item">
                    <div class="notice-header"><span class="notice-badge badge-critical">심각</span><span style="color:var(--text-sub)">09:25</span></div>
                    <div>Rack #3 통신 단절</div>
                </div>
            </div>
        </div>

        <div class="panel-box">
            <h5 style="margin:0; color:#f56565;">실시간 고장 목록</h5>
            <p style="font-size:0.7rem; color:var(--text-sub); margin:0;">현재 고장 내역 없음</p>
        </div>

        <div class="panel-box" style="flex:1;">
            <h5 style="margin:0; color:var(--accent);">최근 제어 이력</h5>
            <div id="control-log-container" style="overflow-y:auto;">
                <div class="log-item">
                    <div class="log-header"><span style="color:var(--text-sub)">09:15:30</span><span class="log-status status-success">성공</span></div>
                    <div>Inverter #1 운전 시작</div>
                    <div style="font-size:0.65rem; color:var(--accent)">작업자: admin</div>
                </div>
            </div>
        </div>
    </aside>
</div>

<script src="js/9.monitoring.js"></script>

</body>
</html>
